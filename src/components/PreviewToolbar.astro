---
import type { KnownLocale } from '../types';

interface Props {
  currentLocale: KnownLocale;
  localeUrls?: Partial<Record<KnownLocale, string>>;
}

const { currentLocale, localeUrls = {} } = Astro.props;

const otherLocales = Object.entries(localeUrls).filter(([l]) => l !== currentLocale) as [
  KnownLocale,
  string,
][];
---

<nav class="preview-toolbar">
  {
    otherLocales.length > 0 && (
      <div class="locale-group">
        <span class="locale-current">{currentLocale.toUpperCase()}</span>
        {otherLocales.map(([locale, url]) => (
          <a href={url} class="btn-locale">
            {locale.toUpperCase()}
          </a>
        ))}
      </div>
    )
  }

  <button id="theme-toggle" class="btn-theme" aria-label="Toggle theme" title="Toggle theme">
    <span class="theme-icon"></span>
  </button>
</nav>

<script>
  function initToolbar() {
    const btn = document.getElementById('theme-toggle');
    if (!btn) return;

    const applyTheme = (theme: string) => {
      document.documentElement.classList.remove('theme-light', 'theme-dark');
      document.documentElement.classList.add(theme);
      localStorage.setItem('theme', theme);
    };

    btn.addEventListener('click', () => {
      const next = document.documentElement.classList.contains('theme-dark')
        ? 'theme-light'
        : 'theme-dark';
      applyTheme(next);
    });
  }

  initToolbar();
  document.addEventListener('astro:after-swap', initToolbar);
</script>

<style>
  .preview-toolbar {
    position: fixed;
    top: 1rem;
    right: 1.5rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    z-index: 1000;
    background: var(--bg-surface);
    padding: 0.4rem;
    border-radius: 1rem;
    border: 1px solid var(--border-color);
    backdrop-filter: blur(12px);
  }

  .locale-group {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    padding-right: 0.5rem;
    border-right: 1px solid var(--border-color);
  }

  .locale-current {
    font-size: 0.7rem;
    font-weight: 900;
    color: var(--text-muted);
    padding: 0.4rem 0.6rem;
    letter-spacing: 0.08em;
  }

  .btn-locale {
    background: transparent;
    border: 1px solid var(--border-color);
    color: var(--text-main);
    cursor: pointer;
    padding: 0.4rem 0.7rem;
    border-radius: 0.5rem;
    font-weight: 700;
    font-size: 0.7rem;
    text-decoration: none;
    letter-spacing: 0.08em;
    transition: all 0.2s ease;
  }

  .btn-locale:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  .btn-theme {
    background: transparent;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
    border-radius: 0.6rem;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s ease;
  }

  .btn-theme:hover {
    background: rgba(255, 255, 255, 0.08);
  }

  .theme-icon {
    display: block;
    width: 16px;
    height: 16px;
    border-radius: 50%;
  }

  :global(.theme-light) .theme-icon {
    background: #f59e0b;
    box-shadow: 0 0 8px #fbbf24;
  }

  :global(.theme-dark) .theme-icon {
    background: #94a3b8;
    box-shadow: inset -4px -2px 0 #1e293b;
  }
</style>


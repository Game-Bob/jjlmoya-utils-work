---
import type { ResignationLetterGeneratorUI } from './ui';

interface Props {
  ui?: Record<string, unknown>;
}

const { ui = {} } = Astro.props;
const t = ui as ResignationLetterGeneratorUI;
---

<div
  id="rl-root"
  class="rl-root"
  data-date-locale={t.dateLocale}
  data-date-prefix={t.datePrefix}
  data-manager-prefix={t.managerPrefix}
  data-manager-fallback={t.managerFallback}
  data-company-fallback={t.companyFallback}
  data-sal-neutral={t.salutationNeutral}
  data-sal-m={t.salutationM}
  data-sal-f={t.salutationF}
  data-salutation-fallback={t.salutationFallback}
  data-signature-fallback={t.signatureFallback}
  data-default-user-name={t.defaultUserName}
  data-default-manager-name={t.defaultManagerName}
  data-default-company-name={t.defaultCompanyName}
  data-default-city={t.defaultCity}
  data-copy-feedback={t.copyFeedback}
  data-reason-standard={t.reasonStandard}
  data-reason-opportunity={t.reasonOpportunity}
  data-reason-personal={t.reasonPersonal}
  data-reason-education={t.reasonEducation}
  data-reason-growth={t.reasonGrowth}
  data-reason-direct={t.reasonDirect}
>
  <div class="rl-tool-content">
    <div class="rl-form-container">
      <div class="rl-form-group">
        <label for="rl-user">{t.labelUserName}</label>
        <input type="text" id="rl-user" />
      </div>

      <div class="rl-form-group">
        <label for="rl-manager">{t.labelManagerName}</label>
        <input type="text" id="rl-manager" />
      </div>

      <div class="rl-form-group">
        <label for="rl-gender">{t.labelManagerGender}</label>
        <select id="rl-gender">
          <option value="gender-neutral">{t.optGenderNeutral}</option>
          <option value="gender-m">{t.optGenderM}</option>
          <option value="gender-f">{t.optGenderF}</option>
        </select>
      </div>

      <div class="rl-form-group">
        <label for="rl-company">{t.labelCompanyName}</label>
        <input type="text" id="rl-company" />
      </div>

      <div class="rl-form-group">
        <label for="rl-last-day">{t.labelLastDay}</label>
        <input type="date" id="rl-last-day" />
      </div>

      <div class="rl-form-group">
        <label for="rl-reason">{t.labelReasonType}</label>
        <select id="rl-reason">
          <option value="standard">{t.optReasonStandard}</option>
          <option value="opportunity">{t.optReasonOpportunity}</option>
          <option value="personal">{t.optReasonPersonal}</option>
          <option value="education">{t.optReasonEducation}</option>
          <option value="growth">{t.optReasonGrowth}</option>
          <option value="direct">{t.optReasonDirect}</option>
        </select>
      </div>

      <div class="rl-form-group">
        <label for="rl-city">{t.labelCity}</label>
        <input type="text" id="rl-city" />
      </div>

      <div class="rl-actions">
        <button id="rl-copy-btn" class="rl-btn rl-btn-primary">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
            <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
          </svg>
          {t.btnCopy}
        </button>
        <button id="rl-download-btn" class="rl-btn rl-btn-secondary">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
            <polyline points="7 10 12 15 17 10"></polyline>
            <line x1="12" y1="15" x2="12" y2="3"></line>
          </svg>
          {t.btnDownload}
        </button>
      </div>
    </div>

    <div class="rl-preview-container">
      <div id="rl-copy-feedback" class="rl-copy-feedback">{t.copyFeedback}</div>
      <div id="rl-letter-preview" class="rl-letter-content">
        <div class="rl-letter-header">
          <p id="rl-preview-date" class="rl-date-line"></p>
          <div class="rl-to-block">
            <p id="rl-preview-manager"></p>
            <p id="rl-preview-company" class="rl-company-name"></p>
          </div>
        </div>

        <div class="rl-letter-body-section">
          <p class="rl-salutation-line">
            <span id="rl-sal-prefix">{t.salutationNeutral}</span>
            <span id="rl-sal-name">{t.salutationFallback}</span>:
          </p>
          <p id="rl-preview-body" class="rl-para"></p>
          <p class="rl-para">{t.thanksParagraph}</p>
          <p class="rl-para">{t.transitionParagraph}</p>
        </div>

        <div class="rl-letter-footer">
          <p>{t.closingWord}</p>
          <p id="rl-preview-signature" class="rl-signature"></p>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  import {
    buildDateLine,
    buildManagerLine,
    getFirstName,
    buildSalutation,
    buildMainBody,
  } from './logic';

  type FormInputs = {
    user: HTMLInputElement;
    manager: HTMLInputElement;
    company: HTMLInputElement;
    lastDay: HTMLInputElement;
    reason: HTMLSelectElement;
    city: HTMLInputElement;
    gender: HTMLSelectElement;
  };

  function getEl(id: string): HTMLElement | null {
    return document.getElementById(id);
  }

  function setText(id: string, text: string) {
    const el = getEl(id);
    if (el) el.textContent = text;
  }

  function getFormInputs(): FormInputs | null {
    const user = getEl('rl-user') as HTMLInputElement | null;
    const manager = getEl('rl-manager') as HTMLInputElement | null;
    const company = getEl('rl-company') as HTMLInputElement | null;
    const lastDay = getEl('rl-last-day') as HTMLInputElement | null;
    if (!user || !manager || !company || !lastDay) return null;
    const reason = getEl('rl-reason') as HTMLSelectElement | null;
    const city = getEl('rl-city') as HTMLInputElement | null;
    const gender = getEl('rl-gender') as HTMLSelectElement | null;
    if (!reason || !city || !gender) return null;
    return { user, manager, company, lastDay, reason, city, gender };
  }

  function ds(root: HTMLElement, key: string): string {
    return root.dataset[key] || '';
  }

  function setIfEmpty(input: HTMLInputElement, val: string) {
    if (!input.value) input.value = val;
  }

  function getReasonsFromRoot(root: HTMLElement): Record<string, string> {
    const g = (k: string) => ds(root, k);
    return {
      standard: g('reasonStandard'),
      opportunity: g('reasonOpportunity'),
      personal: g('reasonPersonal'),
      education: g('reasonEducation'),
      growth: g('reasonGrowth'),
      direct: g('reasonDirect'),
    };
  }

  function updateLetterHeader(inputs: FormInputs, root: HTMLElement) {
    const city = inputs.city.value || ds(root, 'defaultCity');
    const locale = ds(root, 'dateLocale') || 'es-ES';
    setText('rl-preview-date', buildDateLine(city, locale, ds(root, 'datePrefix')));
    setText('rl-preview-manager', buildManagerLine(inputs.manager.value, ds(root, 'managerPrefix'), ds(root, 'managerFallback')));
    setText('rl-preview-company', inputs.company.value || ds(root, 'companyFallback'));
  }

  function updateLetterSalutation(inputs: FormInputs, root: HTMLElement) {
    const pfx = buildSalutation(inputs.gender.value, ds(root, 'salNeutral'), ds(root, 'salM'), ds(root, 'salF'));
    const name = getFirstName(inputs.manager.value) || ds(root, 'salutationFallback');
    setText('rl-sal-prefix', pfx);
    setText('rl-sal-name', name);
  }

  function updateLetterBody(inputs: FormInputs, root: HTMLElement) {
    const reasons = getReasonsFromRoot(root);
    const locale = ds(root, 'dateLocale') || 'es-ES';
    setText('rl-preview-body', buildMainBody(inputs.reason.value, inputs.lastDay.value, reasons, locale));
    setText('rl-preview-signature', inputs.user.value || ds(root, 'signatureFallback'));
  }

  function updatePreview() {
    const root = getEl('rl-root') as HTMLElement | null;
    const inputs = getFormInputs();
    if (!root || !inputs) return;
    updateLetterHeader(inputs, root);
    updateLetterSalutation(inputs, root);
    updateLetterBody(inputs, root);
  }

  function setInitialValues(inputs: FormInputs, root: HTMLElement) {
    const future = new Date(Date.now() + 15 * 24 * 60 * 60 * 1000);
    setIfEmpty(inputs.user, ds(root, 'defaultUserName'));
    setIfEmpty(inputs.manager, ds(root, 'defaultManagerName'));
    setIfEmpty(inputs.company, ds(root, 'defaultCompanyName'));
    setIfEmpty(inputs.city, ds(root, 'defaultCity'));
    setIfEmpty(inputs.lastDay, future.toISOString().split('T')[0] || '');
  }

  function setupListeners() {
    const inputs = getFormInputs();
    if (!inputs) return;
    const elems = [inputs.user, inputs.manager, inputs.company, inputs.lastDay, inputs.reason, inputs.city, inputs.gender];
    elems.forEach((el) => el.addEventListener('input', updatePreview));
  }

  async function handleCopy() {
    const el = getEl('rl-letter-preview') as HTMLElement | null;
    if (!el) return;
    await navigator.clipboard.writeText(el.innerText);
    const fb = getEl('rl-copy-feedback');
    if (!fb) return;
    fb.classList.add('rl-show');
    setTimeout(() => fb.classList.remove('rl-show'), 2000);
  }

  async function handleDownload() {
    const el = getEl('rl-letter-preview');
    if (!el) return;
    const html2pdf = (await import('html2pdf.js')).default;
    await html2pdf()
      .set({
        margin: 0,
        filename: 'resignation-letter.pdf',
        image: { type: 'jpeg', quality: 0.98 },
        html2canvas: { scale: 2, useCORS: true },
        jsPDF: { unit: 'px', format: [794, 1123], orientation: 'portrait' },
      })
      .from(el)
      .save();
  }

  function setupButtons() {
    const copyBtn = getEl('rl-copy-btn');
    const downloadBtn = getEl('rl-download-btn');
    copyBtn?.addEventListener('click', () => { void handleCopy(); });
    downloadBtn?.addEventListener('click', () => { void handleDownload(); });
  }

  function init() {
    const root = getEl('rl-root') as HTMLElement | null;
    const inputs = getFormInputs();
    if (!root || !inputs) return;
    setInitialValues(inputs, root);
    setupListeners();
    setupButtons();
    updatePreview();
  }

  init();
</script>


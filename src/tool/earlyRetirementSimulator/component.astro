---
import type { EarlyRetirementSimulatorUI } from './ui';

interface Props {
  ui?: Record<string, unknown>;
}

const { ui = {} } = Astro.props;
const t = ui as EarlyRetirementSimulatorUI;
---

<div
  class="er-desk"
  id="er-root"
  data-label-years={t.labelYears}
  data-advice-delay={t.adviceDelay}
  data-advice-bonus={t.adviceBonus}
  data-advice-optimal={t.adviceOptimal}
>
  <header class="er-header">
    <div class="er-pill">
      <span class="er-pill-label">{t.labelBirthYear}</span>
      <input
        type="number"
        id="er-birth"
        class="er-pill-input"
        value={t.defaultBirthYear}
        min="1950"
        max="2010"
      />
    </div>
    <div class="er-pill">
      <span class="er-pill-label">{t.labelContributions}</span>
      <input
        type="number"
        id="er-contributions"
        class="er-pill-input"
        value={t.defaultContributions}
        min="0"
        max="50"
      />
    </div>
    <div class="er-pill er-pill-right">
      <span class="er-pill-label">{t.labelBasePension}</span>
      <div class="er-pill-row">
        <input
          type="number"
          id="er-base"
          class="er-pill-input er-pill-input-narrow"
          value={t.defaultBasePension}
        />
        <span class="er-currency">€</span>
      </div>
    </div>
  </header>

  <div class="er-body">
    <nav class="er-sidebar">
      <button class="er-nav-btn" data-mode="legal">
        <span class="er-btn-title">{t.btnLegalTitle}</span>
        <span class="er-btn-desc">{t.btnLegalDesc}</span>
      </button>
      <button class="er-nav-btn er-active" data-mode="voluntaria">
        <span class="er-btn-title">{t.btnVoluntaryTitle}</span>
        <span class="er-btn-desc">{t.btnVoluntaryDesc}</span>
      </button>
      <button class="er-nav-btn" data-mode="involuntaria">
        <span class="er-btn-title">{t.btnInvoluntaryTitle}</span>
        <span class="er-btn-desc">{t.btnInvoluntaryDesc}</span>
      </button>
    </nav>

    <main class="er-main">
      <div class="er-result-hero">
        <div class="er-metric-group">
          <span class="er-pill-label">{t.labelRetirementAge}</span>
          <div class="er-metric-large" id="er-val-age">65<span>{t.labelYears}</span></div>
        </div>
        <div class="er-metric-group er-metric-group-right">
          <span class="er-pill-label">{t.labelExpectedDate}</span>
          <div class="er-stat-val" id="er-val-date">2040</div>
        </div>
      </div>

      <div class="er-slider-unit">
        <input
          type="range"
          id="er-slider"
          class="er-range"
          min="61"
          max="70"
          step="1"
          value="65"
        />
        <div class="er-node-grid">
          <span class="er-node-year">61</span>
          <span class="er-node-year">63</span>
          <span class="er-node-year">65</span>
          <span class="er-node-year">67</span>
          <span class="er-node-year">70</span>
        </div>
      </div>

      <div class="er-stats-footer">
        <div class="er-stat-box">
          <span class="er-pill-label">{t.labelEstimatedPension}</span>
          <div class="er-stat-val" id="er-val-pension">1.975,00 €</div>
        </div>
        <div class="er-stat-box er-stat-box-right">
          <span class="er-pill-label">{t.labelPermanentReduction}</span>
          <div class="er-stat-val er-stat-accent" id="er-val-penalty">-21.0%</div>
        </div>
      </div>
    </main>
  </div>

  <footer class="er-advice-bar">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" class="er-advice-icon">
      <path d="M12 2a7 7 0 0 1 5.292 11.595l-.292.352V17a1 1 0 0 1-.883.993L16 18h-1v2a1 1 0 0 1-.883.993L14 21h-4a1 1 0 0 1-.993-.883L9 20v-2H8a1 1 0 0 1-.993-.883L7 17v-3.053l-.292-.352A7 7 0 0 1 12 2zm0 2a5 5 0 0 0-3.772 8.302l.353.423.419.504V17h6v-3.771l.419-.504.353-.423A5 5 0 0 0 12 4zm1 13h-2v1h2v-1z"/>
    </svg>
    <span id="er-val-advice">{t.adviceDefault}</span>
  </footer>
</div>

<script>
  import {
    calcTotalContributed,
    getLegalAge,
    calcPenalty,
  } from './logic';

  let currentMode = 'voluntaria';

  function getEl(id: string): HTMLElement | null {
    return document.getElementById(id);
  }

  function ds(root: HTMLElement, key: string): string {
    return root.dataset[key] || '';
  }

  function formatCurrency(val: number): string {
    return new Intl.NumberFormat('es-ES', { style: 'currency', currency: 'EUR' }).format(val);
  }

  function parseNum(s: string, fallback: number): number {
    const n = Number(s);
    return Number.isNaN(n) ? fallback : n;
  }

  function getPenaltyText(penalty: number): string {
    if (penalty > 0) return `-${penalty.toFixed(1)}%`;
    if (penalty < 0) return `+${Math.abs(penalty).toFixed(1)}%`;
    return '0.0%';
  }

  function getPenaltyColor(penalty: number): string {
    if (penalty > 0) return 'var(--er-gold)';
    if (penalty < 0) return 'var(--er-emerald)';
    return 'var(--er-deep)';
  }

  function getInputValues() {
    const root = getEl('er-root') as HTMLElement | null;
    const ageSlider = getEl('er-slider') as HTMLInputElement | null;
    const birthIn = getEl('er-birth') as HTMLInputElement | null;
    const curContIn = getEl('er-contributions') as HTMLInputElement | null;
    const baseIn = getEl('er-base') as HTMLInputElement | null;
    if (!root || !ageSlider || !birthIn || !curContIn || !baseIn) return null;
    return {
      root,
      birthYear: parseNum(birthIn.value, 1975),
      curCont: parseNum(curContIn.value, 0),
      base: parseNum(baseIn.value, 0),
      selectedAge: parseNum(ageSlider.value, 65),
    };
  }

  interface DisplayValues {
    selectedAge: number;
    birthYear: number;
    penalty: number;
    finalPension: number;
  }

  function updateDisplay(vals: DisplayValues, root: HTMLElement) {
    const { selectedAge, birthYear, penalty, finalPension } = vals;
    const ageOut = getEl('er-val-age');
    const penaltyOut = getEl('er-val-penalty');
    const dateOut = getEl('er-val-date');
    const pensionOut = getEl('er-val-pension');
    if (ageOut) ageOut.innerHTML = `${selectedAge}<span>${ds(root, 'labelYears')}</span>`;
    if (penaltyOut) {
      penaltyOut.textContent = getPenaltyText(penalty);
      penaltyOut.style.color = getPenaltyColor(penalty);
    }
    if (dateOut) dateOut.textContent = String(birthYear + selectedAge);
    if (pensionOut) pensionOut.textContent = formatCurrency(finalPension);
  }

  function updateAdvice(penalty: number, base: number, selectedAge: number, root: HTMLElement) {
    const adviceOut = getEl('er-val-advice');
    if (!adviceOut) return;
    if (penalty > 0) {
      const gain = Math.round(base * 0.05);
      const template = ds(root, 'adviceDelay');
      adviceOut.innerHTML = template
        .replace('[AGE]', String(selectedAge + 1))
        .replace('[GAIN]', String(gain));
      return;
    }
    if (penalty < 0) {
      adviceOut.textContent = ds(root, 'adviceBonus');
      return;
    }
    adviceOut.textContent = ds(root, 'adviceOptimal');
  }

  function updateDesk() {
    const v = getInputValues();
    if (!v) return;
    const totalContributed = calcTotalContributed(v.curCont, v.birthYear, v.selectedAge);
    const legalAge = getLegalAge(totalContributed);
    const penalty = calcPenalty(currentMode, v.selectedAge, legalAge, totalContributed);
    const finalPension = v.base * (1 - penalty / 100);
    updateDisplay({ selectedAge: v.selectedAge, birthYear: v.birthYear, penalty, finalPension }, v.root);
    updateAdvice(penalty, v.base, v.selectedAge, v.root);
  }

  function handleNavClick(btn: Element, navBtns: NodeListOf<Element>) {
    const slider = getEl('er-slider') as HTMLInputElement | null;
    navBtns.forEach((b) => b.classList.remove('er-active'));
    btn.classList.add('er-active');
    const mode = btn.getAttribute('data-mode') || 'voluntaria';
    currentMode = mode;
    const defaults: Record<string, string> = { legal: '67', involuntaria: '63', voluntaria: '65' };
    if (slider) slider.value = defaults[mode] || '65';
    updateDesk();
  }

  function setupListeners() {
    const navBtns = document.querySelectorAll('.er-nav-btn');
    [getEl('er-birth'), getEl('er-contributions'), getEl('er-base'), getEl('er-slider')].forEach(
      (el) => {
        if (el) el.addEventListener('input', updateDesk);
      }
    );
    navBtns.forEach((btn) => {
      btn.addEventListener('click', () => handleNavClick(btn, navBtns));
    });
  }

  setupListeners();
  updateDesk();
</script>


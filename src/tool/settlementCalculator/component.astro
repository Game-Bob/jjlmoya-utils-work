---
import type { SettlementCalculatorUI } from './ui';

interface Props {
  ui?: Record<string, unknown>;
}

const { ui = {} } = Astro.props;
const t = ui as SettlementCalculatorUI;
---

<div
  class="sc-root"
  id="sc-root"
  data-label-total={t.labelTotal}
  data-label-severance={t.labelSeverance}
  data-label-vacation={t.labelVacation}
  data-label-extras={t.labelExtras}
  data-label-month={t.labelMonthSalary}
  data-copy-title={t.copySummaryTitle}
  data-copy-success={t.copySuccess}
>
  <div class="sc-card">
    <div class="sc-input-grid">
      <div class="sc-input-group">
        <label for="sc-salary">{t.labelSalary}</label>
        <div class="sc-input-wrap">
          <input
            type="number"
            id="sc-salary"
            min="0"
            value={t.defaultSalary}
          />
          <span class="sc-unit">€</span>
        </div>
      </div>

      <div class="sc-input-group">
        <label for="sc-extra-pays">{t.labelExtraPayments}</label>
        <div class="sc-input-wrap">
          <select id="sc-extra-pays">
            <option value="12">{t.opt12pays}</option>
            <option value="14" selected>{t.opt14pays}</option>
          </select>
        </div>
      </div>

      <div class="sc-input-group">
        <label for="sc-start-date">{t.labelStartDate}</label>
        <div class="sc-input-wrap">
          <input type="date" id="sc-start-date" value="2023-01-01" />
        </div>
      </div>

      <div class="sc-input-group">
        <label for="sc-end-date">{t.labelEndDate}</label>
        <div class="sc-input-wrap">
          <input type="date" id="sc-end-date" value="2025-12-31" />
        </div>
      </div>

      <div class="sc-input-group">
        <label for="sc-vacation">{t.labelVacationDays}</label>
        <div class="sc-input-wrap">
          <input
            type="number"
            id="sc-vacation"
            min="0"
            value="0"
          />
          <span class="sc-unit">días</span>
        </div>
      </div>

      <div class="sc-input-group">
        <label for="sc-reason">{t.labelDepartureReason}</label>
        <div class="sc-input-wrap">
          <select id="sc-reason">
            <option value="improcedente">{t.optImprocedente}</option>
            <option value="objetivo">{t.optObjetivo}</option>
            <option value="temporal">{t.optTemporal}</option>
            <option value="voluntaria" selected>{t.optVoluntaria}</option>
          </select>
        </div>
      </div>
    </div>

    <div class="sc-results">
      <div class="sc-total-header">
        <span class="sc-total-label">{t.labelTotal}</span>
        <span class="sc-total-value" id="sc-total">0,00 €</span>
      </div>

      <div class="sc-breakdown-grid">
        <div class="sc-breakdown-item">
          <span class="sc-breakdown-label">{t.labelSeverance}</span>
          <span class="sc-breakdown-value" id="sc-val-severance">0,00 €</span>
        </div>
        <div class="sc-breakdown-item">
          <span class="sc-breakdown-label">{t.labelVacation}</span>
          <span class="sc-breakdown-value" id="sc-val-vacation">0,00 €</span>
        </div>
        <div class="sc-breakdown-item">
          <span class="sc-breakdown-label">{t.labelExtras}</span>
          <span class="sc-breakdown-value" id="sc-val-extras">0,00 €</span>
        </div>
        <div class="sc-breakdown-item">
          <span class="sc-breakdown-label">{t.labelMonthSalary}</span>
          <span class="sc-breakdown-value" id="sc-val-month">0,00 €</span>
        </div>
      </div>

      <div class="sc-info-alert">
        <svg
          class="sc-info-icon"
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <circle cx="12" cy="12" r="10"></circle>
          <line x1="12" y1="8" x2="12" y2="12"></line>
          <line x1="12" y1="16" x2="12.01" y2="16"></line>
        </svg>
        <p>{t.disclaimer}</p>
      </div>
    </div>

    <div class="sc-action-bar">
      <button class="sc-btn-copy" id="sc-copy-btn">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
          <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
        </svg>
        <span id="sc-copy-label">{t.btnCopy}</span>
      </button>
    </div>
  </div>
</div>

<script>
  import { calculateSettlement } from './logic';
  import type { SettlementResult } from './logic';

  function getEl(id: string): HTMLElement | null {
    return document.getElementById(id);
  }

  function fmt(val: number): string {
    return new Intl.NumberFormat('es-ES', { style: 'currency', currency: 'EUR' }).format(val);
  }

  function getInputs() {
    const salary = getEl('sc-salary') as HTMLInputElement | null;
    const extraPays = getEl('sc-extra-pays') as HTMLSelectElement | null;
    const startDate = getEl('sc-start-date') as HTMLInputElement | null;
    const endDate = getEl('sc-end-date') as HTMLInputElement | null;
    const vacation = getEl('sc-vacation') as HTMLInputElement | null;
    const reason = getEl('sc-reason') as HTMLSelectElement | null;
    if (!salary || !extraPays || !startDate || !endDate || !vacation || !reason) return null;
    return { salary, extraPays, startDate, endDate, vacation, reason };
  }

  function applyResult(result: SettlementResult) {
    const pairs: [string, number][] = [
      ['sc-total', result.total],
      ['sc-val-severance', result.severance],
      ['sc-val-vacation', result.vacation],
      ['sc-val-extras', result.extras],
      ['sc-val-month', result.monthSalary],
    ];
    pairs.forEach(([id, val]) => {
      const el = getEl(id);
      if (el) el.textContent = fmt(val);
    });
    const totalEl = getEl('sc-total');
    totalEl?.classList.add('sc-pulse');
    setTimeout(() => totalEl?.classList.remove('sc-pulse'), 500);
  }

  function recalculate() {
    const inputs = getInputs();
    if (!inputs) return;
    const result = calculateSettlement({
      salaryAnual: parseFloat(inputs.salary.value) || 0,
      extraPagas: parseInt(inputs.extraPays.value) || 12,
      vacationDays: parseFloat(inputs.vacation.value) || 0,
      reason: inputs.reason.value,
      startDate: new Date(inputs.startDate.value),
      endDate: new Date(inputs.endDate.value),
    });
    if (result) applyResult(result);
  }

  function buildSummary(root: HTMLElement): string {
    const d = root.dataset;
    const val = (id: string) => getEl(id)?.textContent ?? '';
    return [
      d.copyTitle ?? '',
      '--------------------------------',
      `${d.labelTotal ?? ''}: ${val('sc-total')}`,
      `${d.labelSeverance ?? ''}: ${val('sc-val-severance')}`,
      `${d.labelVacation ?? ''}: ${val('sc-val-vacation')}`,
      `${d.labelExtras ?? ''}: ${val('sc-val-extras')}`,
      `${d.labelMonth ?? ''}: ${val('sc-val-month')}`,
    ].join('\n');
  }

  function setupCopy() {
    const root = getEl('sc-root') as HTMLElement | null;
    const copyBtn = getEl('sc-copy-btn');
    const copyLabel = getEl('sc-copy-label');
    if (!root || !copyBtn || !copyLabel) return;
    copyBtn.addEventListener('click', () => {
      navigator.clipboard.writeText(buildSummary(root));
      const original = copyLabel.textContent ?? '';
      copyLabel.textContent = root.dataset.copySuccess ?? 'OK';
      setTimeout(() => { copyLabel.textContent = original; }, 2000);
    });
  }

  function setupListeners() {
    const inputs = getInputs();
    if (!inputs) return;
    const elems = [inputs.salary, inputs.extraPays, inputs.startDate, inputs.endDate, inputs.vacation, inputs.reason];
    elems.forEach((el) => el.addEventListener('input', recalculate));
  }

  setupListeners();
  setupCopy();
  recalculate();
</script>


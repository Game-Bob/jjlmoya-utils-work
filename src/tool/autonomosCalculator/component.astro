---
import { Icon } from 'astro-icon/components';
import type { KnownLocale } from '../../types';
import type { AutonomosCalculatorUI } from './ui';

interface Props {
  locale?: KnownLocale;
  ui?: Record<string, unknown>;
}

const { ui } = Astro.props;
const t = (ui ?? {}) as AutonomosCalculatorUI;
---

<div class="ac-container">
  <div class="ac-card">
    <div class="ac-input-grid">
      <div class="ac-input-group">
        <label for="monthly-income">{t.labelIncome}</label>
        <div class="ac-input-wrapper">
          <input
            type="number"
            id="monthly-income"
            placeholder="3000"
            min="0"
            value="3000"
          />
          <span class="ac-input-unit">€</span>
        </div>
      </div>

      <div class="ac-input-group">
        <label for="monthly-expenses">{t.labelExpenses}</label>
        <div class="ac-input-wrapper">
          <input
            type="number"
            id="monthly-expenses"
            placeholder="500"
            min="0"
            value="500"
          />
          <span class="ac-input-unit">€</span>
        </div>
      </div>

      <div class="ac-input-group">
        <label for="autonomo-type">{t.labelType}</label>
        <div class="ac-input-wrapper">
          <select id="autonomo-type">
            <option value="standard">{t.optStandard}</option>
            <option value="societario">{t.optSocietario}</option>
          </select>
        </div>
      </div>

      <div class="ac-input-group">
        <label for="flat-rate">{t.labelFlatRate}</label>
        <div class="ac-input-wrapper">
          <select id="flat-rate">
            <option value="no">{t.optNoFlatRate}</option>
            <option value="yes">{t.optFlatRate}</option>
          </select>
        </div>
      </div>
    </div>

    <div class="ac-bracket-info" id="bracket-info">
      <div class="ac-bracket-title">
        <span>{t.labelBracket}</span>
        <span class="ac-bracket-pill" id="bracket-label">Tramo 3 (Reducido)</span>
      </div>
      <div class="ac-slider-group">
        <input
          type="range"
          id="income-slider"
          min="0"
          max="8000"
          step="50"
          value="3000"
        />
        <p class="ac-net-display-text">
          {t.labelNetDisplay}: <strong id="net-display">0 €</strong>
        </p>
      </div>
    </div>

    <div class="ac-results-grid">
      <div class="ac-result-card ac-highlight">
        <span class="ac-result-label">{t.labelCuota}</span>
        <span class="ac-result-value ac-primary" id="val-cuota">0,00 €</span>
        <span class="ac-projection-label">{t.labelProjection}</span>
      </div>
      <div class="ac-result-card">
        <span class="ac-result-label">{t.labelBase}</span>
        <span class="ac-result-value" id="val-base">0,00 €</span>
      </div>
      <div class="ac-result-card">
        <span class="ac-result-label">{t.labelNetAfter}</span>
        <span class="ac-result-value" id="val-net-after">0,00 €</span>
      </div>
    </div>

    <div class="ac-info-alert">
      <Icon name="mdi:information-outline" class="ac-info-icon" />
      <p>{t.infoText}</p>
    </div>
  </div>
</div>

<script>
  import { AutonomosCalculator } from './logic';

  const incomeInput = document.getElementById('monthly-income') as HTMLInputElement | null;
  const expenseInput = document.getElementById('monthly-expenses') as HTMLInputElement | null;
  const typeSelect = document.getElementById('autonomo-type') as HTMLSelectElement | null;
  const flatRateSelect = document.getElementById('flat-rate') as HTMLSelectElement | null;
  const incomeSlider = document.getElementById('income-slider') as HTMLInputElement | null;

  const cuotaDisplay = document.getElementById('val-cuota');
  const baseDisplay = document.getElementById('val-base');
  const netAfterDisplay = document.getElementById('val-net-after');
  const netDisplay = document.getElementById('net-display');
  const bracketLabel = document.getElementById('bracket-label');

  function formatCurrency(val: number): string {
    return new Intl.NumberFormat('es-ES', {
      style: 'currency',
      currency: 'EUR',
    }).format(val);
  }

  function getNumericValue(el: HTMLInputElement | null): number {
    return parseFloat(el?.value ?? '0') || 0;
  }

  function getSelectValue(el: HTMLSelectElement | null): string {
    return el?.value ?? '';
  }

  function getParams() {
    return {
      income: getNumericValue(incomeInput),
      expenses: getNumericValue(expenseInput),
      isSocietario: getSelectValue(typeSelect) === 'societario',
      isFlatRate: getSelectValue(flatRateSelect) === 'yes',
    };
  }

  function updateUI(results: ReturnType<typeof AutonomosCalculator.calculate>) {
    if (netDisplay) netDisplay.textContent = formatCurrency(results.rendimientoNeto);
    if (cuotaDisplay) cuotaDisplay.textContent = formatCurrency(results.cuota);
    if (baseDisplay) baseDisplay.textContent = formatCurrency(results.baseCotizacion);
    if (netAfterDisplay) netAfterDisplay.textContent = formatCurrency(results.netAfter);
    if (bracketLabel) bracketLabel.textContent = results.bracketLabel;
  }

  function calculate() {
    if (!incomeInput || !expenseInput || !typeSelect || !flatRateSelect) return;
    const params = getParams();
    if (incomeSlider) {
      incomeSlider.value = Math.min(params.income, 8000).toString();
    }
    updateUI(AutonomosCalculator.calculate(params));
  }

  function handleSlider() {
    if (incomeInput && incomeSlider) {
      incomeInput.value = incomeSlider.value;
      calculate();
    }
  }

  [incomeInput, expenseInput, typeSelect, flatRateSelect].forEach((el) => {
    el?.addEventListener('input', calculate);
  });
  incomeSlider?.addEventListener('input', handleSlider);

  calculate();
</script>


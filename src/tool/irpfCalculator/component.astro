---
import type { KnownLocale } from '../../types';
import type { IrpfCalculatorUI } from './ui';

interface Props {
  locale?: KnownLocale;
  ui?: Record<string, unknown>;
}

const { ui } = Astro.props;
const t = (ui ?? {}) as IrpfCalculatorUI;
---

<div class="irpf-container">
  <div class="irpf-main-card">
    <div class="form-section">
      <div class="section-title">
        <span>{t.titleVariables}</span>
      </div>

      <div class="form-grid">
        <div class="input-block full-width">
          <label class="input-label">{t.labelBruto}</label>
          <input type="number" id="bruto-anual" class="irpf-input" placeholder="32.000" value="30000" min="0" />
        </div>

        <div class="input-block">
          <label class="input-label">{t.labelPagas}</label>
          <select id="numero-pagas" class="irpf-select">
            <option value="12">{t.opt12pagas}</option>
            <option value="14" selected>{t.opt14pagas}</option>
          </select>
        </div>

        <div class="input-block">
          <label class="input-label">{t.labelComunidad}</label>
          <select id="comunidad" class="irpf-select">
            <option value="GEN">{t.optGen}</option>
            <option value="MAD">{t.optMad}</option>
            <option value="CAT">{t.optCat}</option>
            <option value="AND">{t.optAnd}</option>
            <option value="VAL">{t.optVal}</option>
            <option value="PV">{t.optPV}</option>
            <option value="NAV">{t.optNav}</option>
          </select>
        </div>

        <div class="input-block">
          <label class="input-label">{t.labelHijos}</label>
          <input type="number" id="hijos" class="irpf-input" value="0" min="0" />
        </div>

        <div class="input-block">
          <label class="input-label">{t.labelDiscapacidad}</label>
          <select id="discapacidad" class="irpf-select">
            <option value="0">{t.optNinguna}</option>
            <option value="33">{t.opt33}</option>
            <option value="65">{t.opt65}</option>
          </select>
        </div>

        <div class="input-block full-width">
          <label class="input-label">{t.labelUnidad}</label>
          <select id="estado-unid" class="irpf-select">
            <option value="soltero" selected>{t.optSoltero}</option>
            <option value="casado-low">{t.optCasadoLow}</option>
            <option value="casado-high">{t.optCasadoHigh}</option>
          </select>
        </div>
      </div>
    </div>

    <div class="results-section">
      <div class="section-title results-title">
        <span>{t.titleCalculo}</span>
      </div>

      <div class="breakdown-card">
        <div class="breakdown-item">
          <span class="breakdown-label">{t.labelSalarioBruto}</span>
          <span id="b-bruto-fmt" class="breakdown-value">---</span>
        </div>
        <div class="breakdown-item">
          <span class="breakdown-label">{t.labelSS}</span>
          <span id="b-ss-fmt" class="breakdown-value negative">---</span>
        </div>
        <div class="breakdown-item">
          <span class="breakdown-label">{t.labelGastos}</span>
          <span id="b-deduct-fmt" class="breakdown-value negative">---</span>
        </div>
        <div class="breakdown-item net-highlight">
          <span class="breakdown-label net-label">{t.labelNetoAnual}</span>
          <span id="b-neto-fmt" class="breakdown-value net-value">---</span>
        </div>
      </div>

      <div class="protagonist-card">
        <div class="protagonista-label">{t.labelRetencionIRPF}</div>
        <div id="p-perc" class="protagonista-value">---</div>
        <div id="p-anual" class="protagonista-sub">---</div>
      </div>

      <div class="breakdown-card">
        <div class="breakdown-item monthly-highlight">
          <span class="breakdown-label">{t.labelNetoMensual}</span>
          <span id="res-mensual-euro" class="breakdown-value monthly-value">---</span>
        </div>
        <div class="breakdown-item marginal-highlight">
          <span class="breakdown-label">{t.labelMarginal}</span>
          <span id="m-marginal" class="breakdown-value marginal-label-red">-- %</span>
        </div>
      </div>

      <div class="info-alert">
        <svg class="info-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
        <div class="info-text">
          {t.infoText}
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  import { TaxCalculator } from './logic';

  const IDs = ['bruto-anual', 'numero-pagas', 'comunidad', 'estado-unid', 'hijos', 'discapacidad'];
  const UI = {
    bBruto: document.getElementById('b-bruto-fmt'),
    bSs: document.getElementById('b-ss-fmt'),
    bDeduct: document.getElementById('b-deduct-fmt'),
    bNeto: document.getElementById('b-neto-fmt'),
    pPerc: document.getElementById('p-perc'),
    pAnual: document.getElementById('p-anual'),
    resM: document.getElementById('res-mensual-euro'),
    marg: document.getElementById('m-marginal'),
  };

  function getParams() {
    return {
      salary: parseFloat((document.getElementById('bruto-anual') as HTMLInputElement).value) || 0,
      pagas: parseInt((document.getElementById('numero-pagas') as HTMLSelectElement).value),
      comunidad: (document.getElementById('comunidad') as HTMLSelectElement).value,
      estado: (document.getElementById('estado-unid') as HTMLSelectElement).value,
      hijos: parseInt((document.getElementById('hijos') as HTMLInputElement).value) || 0,
      discapacidad: parseInt((document.getElementById('discapacidad') as HTMLSelectElement).value),
    };
  }

  function formatEuro(v: number): string {
    const fmtEuro = new Intl.NumberFormat('es-ES', {
      useGrouping: true,
      minimumFractionDigits: 0,
      maximumFractionDigits: 0,
    });
    return fmtEuro.format(Math.round(v)) + ' €';
  }

  function updateBreakdownUI(salaryVal: number, res: ReturnType<typeof TaxCalculator.calculate>) {
    if (UI.bBruto) UI.bBruto.textContent = formatEuro(salaryVal);
    if (UI.bSs) UI.bSs.textContent = `- ${formatEuro(res.ssAnual)} (6,47%)`;
    if (UI.bDeduct) UI.bDeduct.textContent = `- ${formatEuro(res.totalDeducible)}`;
    if (UI.bNeto) UI.bNeto.textContent = formatEuro(res.netAnual);
  }

  function updateResultsUI(res: ReturnType<typeof TaxCalculator.calculate>) {
    if (UI.pPerc) UI.pPerc.textContent = res.irpfPerc.toFixed(2).replace('.', ',') + ' %';
    if (UI.pAnual) UI.pAnual.textContent = formatEuro(res.totalTax) + ' / año';
    if (UI.resM) UI.resM.textContent = formatEuro(res.netMensual);
    if (UI.marg) UI.marg.textContent = `${res.marginal.toFixed(1)} %`;
  }

  function update() {
    const root = document.getElementById('bruto-anual') as HTMLInputElement;
    if (!root) return;

    const params = getParams();
    const res = TaxCalculator.calculate(params);
    updateBreakdownUI(params.salary, res);
    updateResultsUI(res);
  }

  IDs.forEach((id) => {
    const el = document.getElementById(id);
    el?.addEventListener('input', update);
    el?.addEventListener('change', update);
  });

  update();
</script>


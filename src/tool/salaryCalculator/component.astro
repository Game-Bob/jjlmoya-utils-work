---
import type { KnownLocale } from '../../types';
import type { SalaryCalculatorUI } from './ui';

interface Props {
  locale?: KnownLocale;
  ui?: Record<string, unknown>;
}

const { ui } = Astro.props;
const t = (ui ?? {}) as SalaryCalculatorUI;
---

<div class="sn-container">
  <div class="sn-main-grid">
    <div class="sn-form-card">
      <div class="sn-form-section">
        <div class="sn-input-block sn-full-width">
          <label class="sn-label">{t.labelGross}</label>
          <div class="sn-input-wrapper">
            <span class="sn-currency">€</span>
            <input
              type="number"
              id="gross-salary"
              placeholder="30000"
              value="30000"
              class="sn-input"
            />
          </div>
        </div>

        <div class="sn-input-block">
          <label class="sn-label">{t.labelPays}</label>
          <div class="sn-pay-toggle">
            <button class="sn-pay-btn sn-active" data-val="12">
              {t.btn12}
            </button>
            <button class="sn-pay-btn" data-val="14">
              {t.btn14}
            </button>
          </div>
        </div>

        <div class="sn-secondary-inputs">
          <div class="sn-input-row">
            <label class="sn-label-inline">{t.labelAge}</label>
            <input
              type="number"
              id="age"
              value="30"
              class="sn-input-small"
            />
          </div>
          <div class="sn-input-row">
            <label class="sn-label-inline">{t.labelContract}</label>
            <select id="contract-type" class="sn-select-small">
              <option value="general">{t.optIndefinite}</option>
              <option value="temporal">{t.optTemporal}</option>
            </select>
          </div>
        </div>

        <button id="calculate-btn" class="sn-calculate-btn">
          {t.btnCalculate}
        </button>
      </div>
    </div>

    <div class="sn-results-column">
      <div class="sn-result-card sn-gradient">
        <p class="sn-result-label">{t.labelNetMonthly}</p>
        <div id="net-monthly" class="sn-result-value">0 €</div>

        <div class="sn-result-footer">
          <div>
            <p class="sn-result-label-small">{t.labelNetAnnual}</p>
            <p id="net-annual" class="sn-result-value-small">0 €</p>
          </div>
          <div class="sn-result-right">
            <p class="sn-result-label-small">{t.labelPaysDisplay}</p>
            <p id="pay-input-display" class="sn-result-value-small">12</p>
          </div>
        </div>
      </div>

      <div class="sn-breakdown-card">
        <h4 class="sn-breakdown-title">{t.labelBreakdown}</h4>

        <div class="sn-breakdown-items">
          <div class="sn-breakdown-row">
            <span class="sn-breakdown-label">
              {t.labelIRPF} (<span id="irpf-percent">0</span>%)
            </span>
            <span id="irpf-amount" class="sn-breakdown-value sn-negative">
              - 0 €
            </span>
          </div>
          <div class="sn-breakdown-row">
            <span class="sn-breakdown-label">
              {t.labelSS} (<span id="ss-percent">6.35</span>%)
            </span>
            <span id="ss-amount" class="sn-breakdown-value sn-negative">
              - 0 €
            </span>
          </div>
        </div>

        <div class="sn-disclaimer">
          <a href="#">{t.disclaimer}</a>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  import { SalaryCalculator } from './logic';

  const grossInput = document.getElementById('gross-salary') as HTMLInputElement;
  const calculateBtn = document.getElementById('calculate-btn');
  const payBtns = document.querySelectorAll('.sn-pay-btn');
  const payDisplay = document.getElementById('pay-input-display');

  const netMonthlyEl = document.getElementById('net-monthly');
  const netAnnualEl = document.getElementById('net-annual');
  const irpfPercentEl = document.getElementById('irpf-percent');
  const irpfAmountEl = document.getElementById('irpf-amount');
  const ssAmountEl = document.getElementById('ss-amount');

  let pays = 12;

  function formatEuro(value: number): string {
    return new Intl.NumberFormat('es-ES', {
      style: 'currency',
      currency: 'EUR',
      maximumFractionDigits: 0,
    }).format(value);
  }

  function updateResults() {
    const gross = parseFloat(grossInput.value) || 0;
    if (gross < 0) return;

    const results = SalaryCalculator.calculate(gross, pays);

    if (netMonthlyEl) netMonthlyEl.textContent = formatEuro(results.netMonthly);
    if (netAnnualEl) netAnnualEl.textContent = formatEuro(results.net);
    if (irpfPercentEl)
      irpfPercentEl.textContent = results.irpfPercent.toFixed(1);
    if (irpfAmountEl) irpfAmountEl.textContent = `- ${formatEuro(results.irpfTotal)}`;
    if (ssAmountEl) ssAmountEl.textContent = `- ${formatEuro(results.ssTotal)}`;
  }

  function handlePayClick(e: Event) {
    const target = e.target as HTMLElement;
    payBtns.forEach((btn) => btn.classList.remove('sn-active'));
    target.classList.add('sn-active');
    pays = parseInt(target.getAttribute('data-val') || '12');
    if (payDisplay) payDisplay.textContent = pays.toString();
    updateResults();
  }

  grossInput.addEventListener('input', updateResults);
  calculateBtn?.addEventListener('click', updateResults);
  payBtns.forEach((btn) => btn.addEventListener('click', handlePayClick));

  updateResults();
</script>

